{
    "name": "@node-runner/api",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch --env-file=.env src/server.ts",
        "build": "tsc",
        "start": "node --env-file=.env dist/server.js",
        "lint": "tsc --noEmit",
        "test": "vitest run",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:studio": "prisma studio",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@fastify/cors": "^10.0.1",
        "@fastify/rate-limit": "^10.2.1",
        "@node-runner/core": "workspace:*",
        "@node-runner/schemas": "workspace:*",
        "@node-runner/shared": "workspace:*",
        "@prisma/client": "^6.2.1",
        "fastify": "^5.2.1",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@types/node": "^22.10.5",
        "pino-pretty": "^13.1.3",
        "prisma": "^6.2.1",
        "tsx": "^4.19.2",
        "typescript": "^5.7.3",
        "vitest": "^3.0.4"
    }
}